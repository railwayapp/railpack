{
 "deploy": {
  "base": {
   "step": "setup:user"
  },
  "inputs": [
   {
    "include": [
     "."
    ],
    "step": "defaultsToUsing"
   },
   {
    "include": [
     "."
    ],
    "step": "usesSecrets"
   }
  ],
  "startCommand": "./run.sh",
  "user": "1001"
 },
 "secrets": [
  "MY_SECRET",
  "MY_OTHER_SECRET",
  "HELLO_WORLD"
 ],
 "steps": [
  {
   "inputs": [
    {
     "image": "ghcr.io/railwayapp/railpack-builder:mise-2026.3.17"
    }
   ],
   "name": "packages:mise"
  },
  {
   "commands": [
    {
     "dest": ".",
     "src": "."
    },
    {
     "cmd": "sh -c './run.sh'",
     "customName": "./run.sh"
    }
   ],
   "inputs": [
    {
     "step": "packages:mise"
    }
   ],
   "name": "defaultsToUsing",
   "secrets": [
    "*"
   ],
   "variables": {
    "NOT_SECRET": "not secret"
   }
  },
  {
   "commands": [
    {
     "dest": ".",
     "src": "."
    },
    {
     "cmd": "sh -c './run.sh'",
     "customName": "./run.sh"
    }
   ],
   "inputs": [
    {
     "step": "packages:mise"
    }
   ],
   "name": "usesSecrets",
   "secrets": [
    "MY_SECRET",
    "MY_OTHER_SECRET"
   ],
   "variables": {
    "NOT_SECRET": "not secret"
   }
  },
  {
   "commands": [
    {
     "cmd": "groupadd -g 1001 railpack \u0026\u0026 useradd -u 1001 -g railpack -m -s /bin/bash railpack \u0026\u0026 chown -R 1001:1001 /app",
     "customName": "create non-root user"
    }
   ],
   "inputs": [
    {
     "image": "ghcr.io/railwayapp/railpack-runtime:mise-2026.3.17"
    }
   ],
   "name": "setup:user"
  }
 ]
}