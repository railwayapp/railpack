{
 "deploy": {
  "base": {
   "image": "ghcr.io/railwayapp/railpack-runtime:mise-2026.7.6"
  },
  "inputs": [
   {
    "include": [
     "."
    ],
    "step": "build"
   }
  ],
  "startCommand": "sh start.sh",
  "variables": {
   "RAILPACK_VERSION": "dev"
  }
 },
 "steps": [
  {
   "inputs": [
    {
     "image": "ghcr.io/railwayapp/railpack-builder:mise-2026.7.6"
    }
   ],
   "name": "packages:mise"
  },
  {
   "commands": [
    {
     "cmd": "chmod +x start.sh"
    }
   ],
   "inputs": [
    {
     "step": "packages:mise"
    },
    {
     "include": [
      "."
     ],
     "local": true
    }
   ],
   "name": "build",
   "secrets": [
    "*"
   ]
  }
 ]
}