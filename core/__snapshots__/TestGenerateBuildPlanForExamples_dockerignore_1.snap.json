{
 "deploy": {
  "base": {
   "step": "setup:user"
  },
  "inputs": [
   {
    "include": [
     "."
    ],
    "step": "build"
   }
  ],
  "startCommand": "sh start.sh",
  "user": "1001"
 },
 "steps": [
  {
   "inputs": [
    {
     "image": "ghcr.io/railwayapp/railpack-builder:mise-2026.3.17"
    }
   ],
   "name": "packages:mise"
  },
  {
   "commands": [
    {
     "cmd": "chmod +x start.sh"
    }
   ],
   "inputs": [
    {
     "step": "packages:mise"
    },
    {
     "exclude": [
      ".vscode",
      ".copier",
      ".env-specific",
      ".env*",
      "__pycache__",
      "test",
      "tmp/*",
      "*.log",
      "Justfile",
      "TODO*",
      "README.md",
      "docker-compose*.yml",
      "negation_test/*"
     ],
     "include": [
      ".",
      "negation_test/should_exist.txt",
      "negation_test/existing_folder"
     ],
     "local": true
    }
   ],
   "name": "build",
   "secrets": [
    "*"
   ]
  },
  {
   "commands": [
    {
     "cmd": "groupadd -g 1001 railpack \u0026\u0026 useradd -u 1001 -g railpack -m -s /bin/bash railpack \u0026\u0026 chown -R 1001:1001 /app",
     "customName": "create non-root user"
    }
   ],
   "inputs": [
    {
     "image": "ghcr.io/railwayapp/railpack-runtime:mise-2026.3.17"
    }
   ],
   "name": "setup:user"
  }
 ]
}