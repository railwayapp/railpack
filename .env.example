# Mise installation directories (Windows: use C:\tmp\railpack\mise)
RAILPACK_MISE_DIR=/tmp/railpack/mise
RAILPACK_MISE_TEST_DIR=/tmp/railpack/mise-test

# BuildKit connection
BUILDKIT_HOST=docker-container://buildkit

# GitHub token for mise to avoid rate limiting
GITHUB_TOKEN=your_github_token_here

# Cache control (disable specific caches or all with "*")
# RAILPACK_DISABLE_CACHES=apt npm-install
# RAILPACK_DISABLE_CACHES=*

# Terminal color control
# FORCE_COLOR=1
# NO_COLOR=1