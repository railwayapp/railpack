  {
    // python.compile = true + PYTHON_BUILD_FREE_THREADING = 1 in mise.toml compiles a freethreaded Python from source
    "expectedOutput": "Free-threaded build: True"
  },
  {
    // Run under x86 emulation to verify the precompiled freethreaded flavor works on amd64.
